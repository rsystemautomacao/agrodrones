<%- include('../partials/header') %>

<div class="page-header">
  <h1 class="page-title"><%= drone && drone._id ? 'Editar Drone' : 'Novo Drone' %></h1>
  <a href="/drones" class="btn btn-outline">Voltar</a>
</div>

<div class="card">
  <% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form method="POST" action="<%= drone && drone._id ? '/drones/' + drone._id : '/drones' %>">

    <h3 class="section-subtitle">Dados da Aeronave (ARP)</h3>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label required">Marca/Modelo</label>
        <input type="text" name="marcaModelo" class="form-input"
          value="<%= drone ? drone.marcaModelo : '' %>" required placeholder="Ex: DJI Agras T40">
      </div>
      <div class="form-group">
        <label class="form-label required">Identificação/Registro (ANAC)</label>
        <input type="text" name="identificacaoRegistro" class="form-input"
          value="<%= drone ? drone.identificacaoRegistro : '' %>" required placeholder="Ex: PP-XAB">
      </div>
      <div class="form-group">
        <label class="form-label">Capacidade do Tanque (L)</label>
        <input type="number" step="0.1" name="capacidadeTanque" class="form-input"
          value="<%= drone && drone.capacidadeTanque ? drone.capacidadeTanque : '' %>" placeholder="Ex: 40">
      </div>
    </div>

    <div class="form-divider"></div>
    <h3 class="section-subtitle">Controle de Manutenção</h3>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Horas de Voo Acumuladas</label>
        <input type="number" step="0.1" name="horasVooTotal" class="form-input"
          value="<%= drone && drone.manutencao ? drone.manutencao.horasVooTotal : '0' %>"
          placeholder="Ex: 127.5">
        <small class="text-muted">Atualize após cada jornada de campo</small>
      </div>
      <div class="form-group">
        <label class="form-label">Intervalo de Revisão (horas de voo)</label>
        <input type="number" step="1" name="intervaloManutencao" class="form-input"
          value="<%= drone && drone.manutencao && drone.manutencao.intervaloManutencao ? drone.manutencao.intervaloManutencao : '50' %>"
          placeholder="Ex: 50">
        <small class="text-muted">Alerta quando se aproximar da próxima revisão</small>
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Data da Última Manutenção</label>
        <input type="date" name="dataUltimaManutencao" class="form-input"
          value="<%= drone && drone.manutencao && drone.manutencao.dataUltimaManutencao ? new Date(drone.manutencao.dataUltimaManutencao).toISOString().slice(0,10) : '' %>">
      </div>
      <div class="form-group">
        <label class="form-label">Próxima Manutenção Prevista</label>
        <input type="date" name="proximaManutencaoData" class="form-input"
          value="<%= drone && drone.manutencao && drone.manutencao.proximaManutencaoData ? new Date(drone.manutencao.proximaManutencaoData).toISOString().slice(0,10) : '' %>">
      </div>
    </div>

    <div class="form-group">
      <label class="form-label">Observações</label>
      <textarea name="observacoes" class="form-textarea"><%= drone ? drone.observacoes : '' %></textarea>
    </div>

    <div class="d-flex gap-2">
      <a href="/drones" class="btn btn-outline">Cancelar</a>
      <button type="submit" class="btn btn-primary ml-auto">Salvar Drone</button>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
