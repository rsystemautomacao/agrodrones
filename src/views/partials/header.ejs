<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>AgroDrones</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/estados-cidades.js" defer></script>
</head>
<body>
  <% if (typeof user !== 'undefined' && user) { %>
  <header class="header">
    <div class="header-container">
      <a href="/dashboard" class="logo">
        <img src="/images/logo.png" alt="AgroDrones" style="height: 40px; margin-right: 10px; vertical-align: middle;">
        <span style="vertical-align: middle;">Agro<span style="color: var(--secondary);">Drones</span></span>
      </a>
      <% const cp = typeof currentPath !== 'undefined' ? currentPath : ''; %>
      <nav class="nav">
        <a href="/dashboard" class="<%= cp === '/dashboard' ? 'active' : '' %>">Dashboard</a>
        <a href="/applications" class="<%= cp.startsWith('/applications') ? 'active' : '' %>">Aplicações</a>
        <a href="/clients" class="<%= cp.startsWith('/clients') ? 'active' : '' %>">Clientes</a>
        <a href="/drones" class="<%= cp.startsWith('/drones') ? 'active' : '' %>">Drones</a>
        <a href="/operators" class="<%= cp.startsWith('/operators') ? 'active' : '' %>">Operadores</a>
        <a href="/reports" class="<%= cp.startsWith('/reports') ? 'active' : '' %>">Relatórios</a>
        <% if (user.role === 'admin') { %>
        <a href="/settings" class="<%= cp.startsWith('/settings') ? 'active' : '' %>">Configurações</a>
        <% } %>
      </nav>
      <div class="user-menu">
        <span class="user-name"><%= user.name %></span>
        <a href="/auth/logout" class="btn-logout">Sair</a>
      </div>
    </div>
  </header>
  <% } %>

